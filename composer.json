{
	"name": "de-swebhosting-typo3-extension/mediaoembed",
	"description": "External media (YouTube, Flickr, ...) content elements using the https://oembed.com/ standard.",
	"license": "GPL-3.0-or-later",
	"type": "typo3-cms-extension",
	"authors": [
		{
			"name": "Alexander Stehlik",
			"email": "alexander.stehlik.deleteme@gmail.com"
		}
	],
	"require": {
		"php": "^8.2",
		"ext-dom": "*",
		"ext-libxml": "*",
		"typo3/cms-core": "~14.3.0"
	},
	"require-dev": {
		"de-swebhosting/typo3-extension-buildtools": "dev-TYPO3_14",
		"michielroos/typo3scan": "dev-master as 1.7.99",
		"phpunit/phpunit": "^11.5.50",
		"ssch/typo3-rector": "^3.14",
		"typo3/cms-filelist": "*",
		"typo3/cms-fluid-styled-content": "*",
		"typo3/cms-install": "*"
	},
	"replace": {
		"typo3-ter/mediaoembed": "self.version"
	},
	"repositories": [
		{
			"type": "package",
			"package": {
				"name": "michielroos/typo3scan",
				"version": "dev-master",
				"bin": [
					"typo3scan"
				],
				"dist": {
					"type": "file",
					"url": "https://github.com/mschwemer/typo3scan-src/raw/refs/heads/master/typo3scan"
				}
			}
		}
	],
	"autoload": {
		"psr-4": {
			"Sto\\Mediaoembed\\": "Classes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Sto\\Mediaoembed\\Tests\\": "Tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"ergebnis/composer-normalize": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"bin-dir": "bin",
		"vendor-dir": ".Build/vendor"
	},
	"extra": {
		"typo3/class-alias-loader": {
			"always-add-alias-loader": true
		},
		"typo3/cms": {
			"extension-key": "mediaoembed",
			"web-dir": ".Build/Web"
		}
	},
	"scripts": {
		"post-autoload-dump": [
			"De\\SWebhosting\\Buildtools\\ExtensionTestEnvironment::prepare"
		]
	}
}
